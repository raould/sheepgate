{
    "files": [
	"./src/onering.ts"
    ],
    "compilerOptions": {
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "module": "commonjs",
        "noErrorTruncation": true,
        "pretty": false,
        "removeComments": true,
        "rootDir": ".",
        "outDir": "out",
        "sourceMap": true,
        "strict": true,
	"target": "ES2019",
	"paths": {
	    "@server/*": ["./OLD/server/src/*"],
	    "@client/*": ["./OLD/client/src/*"],
	    "@resources/*": ["./OLD/client/resources/*"]
	},
        "lib": [
            "es5",
            "es6",
            "dom"
        ]
    },
    "exclude": [
	"./OLD/src/client",
	"./OLD/server/src/server.ts",
        "./node_modules",
        "./out",
	"./build",
	"./.git"
    ]
}
